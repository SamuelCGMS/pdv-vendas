{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "electron.*.config.ts",
    "vite.*.config.ts",
    "apps/*/electron/**/*.ts"
  ]
}
