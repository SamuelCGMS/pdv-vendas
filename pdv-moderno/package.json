{
  "name": "pdv-moderno",
  "productName": "Gravity PDV",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:desktop": "electron-vite dev",
    "dev:web": "vite --config vite.renderer.config.js",
    "build": "npm run typecheck && electron-vite build",
    "build:web": "vite build --config vite.renderer.config.js",
    "lint": "eslint .",
    "preview": "electron-vite preview",
    "preview:web": "vite preview --config vite.renderer.config.js",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^41.0.4",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "^6.0.2",
    "vite": "^7.3.1"
  }
}
